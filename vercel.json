{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@now/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ]
  "redirects": [
    {
      "source": "/",
      "destination": "https://github.com/NaiHeeeee/github-readme-activity-graph"
    }
  ]
}
